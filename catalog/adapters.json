    "wireless-har-wifi-uwb": {
      "handler": "official-profile",
      "implementation": "schema-implemented",
      "patterns": ["**/WiFi_CSI/**/*.csv", "**/WiFi_CSI/**/*.mat", "**/WiFi_CSI/**/*.h5", "**/WiFi_CSI/**/*.hdf5", "**/WiFi_CSI/**/*.npz", "**/WiFi_CSI/**/*.npy"],
