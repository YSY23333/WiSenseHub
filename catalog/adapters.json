      "handler": "official-profile",
      "implementation": "reference-implemented",
      "patterns": ["**/Raw_dataset/WiFi/*.npy", "**/XRF_dataset/train_data/WiFi/*.npy", "**/XRF_dataset/test_data/WiFi/*.npy", "**/train_data/WiFi/*.npy", "**/test_data/WiFi/*.npy"],
