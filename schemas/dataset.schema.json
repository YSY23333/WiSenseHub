{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wisensehub.github.io/schemas/dataset.schema.json",
  "title": "WiSenseHub dataset entry",
  "type": "object",
  "required": ["id", "name", "year", "summary", "tasks", "modalities", "hardware", "settings", "scale", "original", "standardization", "sources", "verified_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$"},
    "name": {"type": "string", "minLength": 2},
    "year": {"type": "integer", "minimum": 2010, "maximum": 2100},
    "summary": {"type": "string", "minLength": 20},
    "tasks": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "modalities": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "hardware": {
      "type": "object",
      "required": ["platform"],
      "properties": {"platform": {"type": "string"}, "chipset": {"type": ["string", "null"]}, "wifi_standard": {"type": ["string", "null"]}, "band": {"type": ["string", "null"]}}
    },
    "settings": {
      "type": "object",
      "required": ["environments", "subjects", "scenario"],
      "properties": {"environments": {"type": ["integer", "null"]}, "subjects": {"type": ["integer", "null"]}, "scenario": {"type": "string"}}
    },
    "scale": {"type": "object"},
    "original": {
      "type": "object",
      "required": ["landing_page", "access", "license", "redistribution", "formats"],
      "properties": {
        "landing_page": {"type": "string", "format": "uri"},
        "download_page": {"type": ["string", "null"]},
        "access": {"enum": ["direct", "account", "application", "unclear"]},
        "license": {"type": "string"},
        "redistribution": {"enum": ["allowed", "restricted", "unclear"]},
        "formats": {"type": "array", "items": {"type": "string"}}
      }
    },
    "standardization": {
      "type": "object",
      "required": ["status", "profile", "notes"],
      "properties": {"status": {"enum": ["planned", "adapter-ready", "verified"]}, "profile": {"type": "string"}, "notes": {"type": "string"}}
    },
    "sources": {
      "type": "array", "minItems": 1,
      "items": {"type": "object", "required": ["type", "url"], "properties": {"type": {"enum": ["paper", "project", "repository", "data"]}, "url": {"type": "string", "format": "uri"}}}
    },
    "verified_at": {"type": "string", "format": "date"}
  },
  "additionalProperties": false
}

